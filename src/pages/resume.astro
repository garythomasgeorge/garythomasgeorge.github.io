---
import BaseLayout from "../layouts/BaseLayout.astro";
import TimelineItem from "../components/TimelineItem.astro";
import ProjectCard from "../components/ProjectCard.astro";
import SkillBadge from "../components/SkillBadge.astro";
import { experience, education, certifications, skillsBuild, skillsHow } from "../data/experience.ts";
import { projects } from "../data/projects.ts";

const summary = `Product Manager with 10+ years building technical products at startups and enterprises. Currently leading conversational AI development at Capgemini for Comcast's Xfinity platform — migrating legacy systems to Google ADK and shipping generative AI features at scale. Personal projects in agentic systems, Flutter apps, and AI tooling reflect a builder-first mindset.`;

const contactLinks = [
  { label: "garytg.com", href: "https://garytg.com" },
  { label: "garythomasgeorge@gmail.com", href: "mailto:garythomasgeorge@gmail.com" },
  { label: "LinkedIn", href: "https://linkedin.com/in/garythomasgeorge" },
  { label: "GitHub", href: "https://github.com/garythomasgeorge" },
];
---

<BaseLayout
  title="Resume"
  description="Resume of Gary Thomas George — Product Manager specializing in conversational AI and agentic systems."
>
  <section class="container-page py-16 md:py-20">
    <header>
      <div class="flex flex-wrap items-start justify-between gap-4">
        <div>
          <p class="label-mono">Resume</p>
          <h1 class="font-serif text-4xl md:text-5xl mt-2">Gary Thomas George</h1>
          <p class="mt-3 text-[var(--color-text-muted)]">Product Manager · Conversational AI · New York</p>
        </div>
        <a
          href="/gary-thomas-george-resume.pdf"
          download
          class="btn-ghost text-sm shrink-0 mt-1"
          aria-label="Download resume as PDF"
        >
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
            <polyline points="7 10 12 15 17 10"/>
            <line x1="12" y1="15" x2="12" y2="3"/>
          </svg>
          Download PDF
        </a>
      </div>

      <ul class="mt-5 flex flex-wrap gap-x-5 gap-y-2 text-sm">
        {contactLinks.map((l) => (
          <li>
            <a
              href={l.href}
              target={l.href.startsWith("http") ? "_blank" : undefined}
              rel={l.href.startsWith("http") ? "noopener noreferrer" : undefined}
              class="link-accent"
            >
              {l.label}
            </a>
          </li>
        ))}
      </ul>
    </header>

    <hr class="hr-fade my-10" />

    <!-- Two-col on desktop, single on mobile -->
    <div class="grid gap-12 md:grid-cols-[1fr_280px]">
      <div class="space-y-14">
        <!-- Summary -->
        <section>
          <h2 class="label-mono mb-4">Summary</h2>
          <p class="text-base leading-relaxed text-[var(--color-text-primary)]">{summary}</p>
        </section>

        <!-- Experience -->
        <section>
          <h2 class="label-mono mb-6">Work Experience</h2>
          <div class="space-y-10">
            {experience.map((e) => (
              <TimelineItem
                company={e.company}
                role={e.role}
                client={e.client}
                product={e.product}
                location={e.location}
                dateRange={`${e.start}–${e.end}`}
                bullets={e.bullets}
                stack={e.stack}
              />
            ))}
          </div>
        </section>

        <!-- Projects -->
        <section>
          <h2 class="label-mono mb-6">Projects</h2>
          <div class="grid gap-4 sm:grid-cols-2">
            {projects.map((p) => <ProjectCard project={p} />)}
          </div>
        </section>
      </div>

      <!-- Sidebar -->
      <aside class="space-y-10">
        <section>
          <h2 class="label-mono mb-4">Skills</h2>
          <h3 class="text-sm text-[var(--color-text-primary)] mb-3">Build</h3>
          <div class="flex flex-wrap gap-1.5 mb-5">
            {skillsBuild.map((s) => <SkillBadge label={s} />)}
          </div>
          <h3 class="text-sm text-[var(--color-text-primary)] mb-3">Approach</h3>
          <ul class="space-y-1.5 text-sm text-[var(--color-text-muted)]">
            {skillsHow.map((s) => <li>{s}</li>)}
          </ul>
        </section>

        <section>
          <h2 class="label-mono mb-4">Education</h2>
          <ul class="space-y-5">
            {education.map((ed) => (
              <li>
                <p class="text-sm text-[var(--color-text-primary)]">{ed.degree}</p>
                <p class="text-sm text-[var(--color-text-muted)]">{ed.school}</p>
                <p class="label-mono mt-1">{ed.start}–{ed.end} · {ed.location}</p>
              </li>
            ))}
          </ul>
        </section>

        <section>
          <h2 class="label-mono mb-4">Certifications</h2>
          <ul class="space-y-3">
            {certifications.map((c) => (
              <li>
                <p class="text-sm text-[var(--color-text-primary)]">{c.name}</p>
                <p class="text-sm text-[var(--color-text-muted)]">{c.issuer}</p>
              </li>
            ))}
          </ul>
        </section>
      </aside>
    </div>
  </section>
</BaseLayout>
