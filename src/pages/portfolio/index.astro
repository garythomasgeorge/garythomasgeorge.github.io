---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ProjectCard from "../../components/ProjectCard.astro";
import { projects } from "../../data/projects.ts";
---

<BaseLayout
  title="Work"
  description="Selected work by Gary Thomas George — enterprise conversational AI projects, personal agentic-systems experiments, and shipped mobile apps."
>
  <section class="container-page py-16 md:py-20">
    <header class="mb-12 max-w-3xl">
      <p class="label-mono">Portfolio</p>
      <h1 class="font-serif text-4xl md:text-5xl mt-2">Work</h1>
      <p class="mt-5 text-lg text-[var(--color-text-muted)] leading-relaxed">
        Enterprise conversational AI projects, personal agentic-systems experiments, and shipped mobile apps. A mix of what I lead at work and what I build on my own.
      </p>
    </header>

    <div class="grid gap-5 md:grid-cols-2 lg:grid-cols-3">
      {projects.map((p) => <ProjectCard project={p} />)}
    </div>
  </section>
</BaseLayout>
