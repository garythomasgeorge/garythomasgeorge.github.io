---
import type { Project } from "../data/projects.ts";
import SkillBadge from "./SkillBadge.astro";

interface Props {
  project: Project;
}
const { project } = Astro.props;
---

<article class="card p-6 flex flex-col gap-4 h-full">
  <div class="flex items-start justify-between gap-3">
    <h3 class="font-serif text-xl leading-tight">{project.name}</h3>
    <span class="label-mono shrink-0 mt-1">{project.type}</span>
  </div>

  <p class="text-sm text-[var(--color-text-muted)] leading-relaxed flex-1">
    {project.blurb}
  </p>

  <div class="flex flex-wrap gap-1.5">
    {project.tags.slice(0, 4).map((t) => <SkillBadge label={t} />)}
  </div>

  <div class="flex flex-wrap gap-x-4 gap-y-2 pt-2 border-t border-[var(--color-border)]">
    {project.links.map((link) => (
      <a
        href={link.href}
        target={link.href.startsWith("http") ? "_blank" : undefined}
        rel={link.href.startsWith("http") ? "noopener noreferrer" : undefined}
        class="text-sm link-accent inline-flex items-center gap-1.5"
      >
        {link.label}
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <line x1="5" y1="12" x2="19" y2="12"/>
          <polyline points="12 5 19 12 12 19"/>
        </svg>
      </a>
    ))}
  </div>
</article>
