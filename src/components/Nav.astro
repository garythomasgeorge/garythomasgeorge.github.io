---
const path = Astro.url.pathname;
const isActive = (href: string) => {
  if (href === "/") return path === "/";
  return path === href || path.startsWith(href + "/");
};

const links = [
  { href: "/portfolio", label: "Work", external: false },
  { href: "/resume", label: "Resume", external: false },
  { href: "https://medium.com/@garythomasgeorge", label: "Writing", external: true },
  { href: "mailto:garythomasgeorge@gmail.com", label: "Contact", external: true },
];
---

<header class="sticky top-0 z-40 backdrop-blur-md bg-[color-mix(in_oklab,var(--color-bg)_75%,transparent)] border-b border-[var(--color-border)]">
  <nav class="container-page flex items-center justify-between h-16">
    <a href="/" class="font-serif text-lg tracking-tight hover:text-[var(--color-accent)] transition-colors" style="color:var(--color-text-primary)">
      Gary Thomas George
    </a>

    <div class="flex items-center gap-4">
      <!-- Desktop links -->
      <ul class="hidden md:flex items-center gap-7">
        {links.map((link) => (
          <li>
            <a
              href={link.href}
              target={link.external ? "_blank" : undefined}
              rel={link.external ? "noopener noreferrer" : undefined}
              class:list={[
                "text-sm transition-colors hover:text-[var(--color-accent)] relative py-1",
                isActive(link.href)
                  ? "after:absolute after:left-0 after:right-0 after:-bottom-0.5 after:h-px after:bg-[var(--color-accent)]"
                  : "",
              ]}
              style={isActive(link.href) ? "color:var(--color-text-primary)" : "color:var(--color-text-muted)"}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>

      <!-- Theme toggle -->
      <button
        id="theme-toggle"
        aria-label="Toggle light / dark mode"
        title="Toggle theme"
        class="w-9 h-9 flex items-center justify-center rounded-md border transition-colors"
        style="border-color:var(--color-border); color:var(--color-text-muted)"
      >
        <!-- Sun icon — shown in dark mode (click to go light) -->
        <svg id="icon-sun" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="4"/>
          <line x1="12" y1="2" x2="12" y2="4"/>
          <line x1="12" y1="20" x2="12" y2="22"/>
          <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
          <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
          <line x1="2" y1="12" x2="4" y2="12"/>
          <line x1="20" y1="12" x2="22" y2="12"/>
          <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
          <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
        </svg>
        <!-- Moon icon — shown in light mode (click to go dark) -->
        <svg id="icon-moon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
      </button>

      <!-- Mobile hamburger (pure-CSS via <details>) -->
      <details class="md:hidden relative group">
        <summary class="list-none cursor-pointer p-2 -m-2" aria-label="Open menu" style="color:var(--color-text-primary)">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round">
            <line x1="4" y1="7" x2="20" y2="7"/>
            <line x1="4" y1="12" x2="20" y2="12"/>
            <line x1="4" y1="17" x2="20" y2="17"/>
          </svg>
        </summary>
        <div class="absolute right-0 top-full mt-3 min-w-[180px] rounded-lg p-2 shadow-xl border" style="background:var(--color-surface); border-color:var(--color-border)">
          <ul class="flex flex-col">
            {links.map((link) => (
              <li>
                <a
                  href={link.href}
                  target={link.external ? "_blank" : undefined}
                  rel={link.external ? "noopener noreferrer" : undefined}
                  class:list={[
                    "block px-3 py-2 rounded-md text-sm transition-colors hover:text-[var(--color-accent)]",
                  ]}
                  style={isActive(link.href) ? "color:var(--color-accent)" : "color:var(--color-text-primary)"}
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      </details>
    </div>
  </nav>
</header>

<style>
  details > summary { list-style: none; }
  details > summary::-webkit-details-marker { display: none; }

  /* Show sun in dark mode, moon in light mode */
  html[data-theme="dark"]  #icon-sun  { display: block; }
  html[data-theme="dark"]  #icon-moon { display: none;  }
  html[data-theme="light"] #icon-sun  { display: none;  }
  html[data-theme="light"] #icon-moon { display: block; }
</style>

<script>
  function applyTheme(theme: string) {
    document.documentElement.setAttribute("data-theme", theme);
    localStorage.setItem("theme", theme);
  }

  const btn = document.getElementById("theme-toggle");
  btn?.addEventListener("click", () => {
    const current = document.documentElement.getAttribute("data-theme");
    applyTheme(current === "light" ? "dark" : "light");
  });
</script>
